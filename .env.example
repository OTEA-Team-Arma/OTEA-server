# OTEA Configuration - Copy this to .env and update values

# Node Environment
NODE_ENV=development
# production = use reverse proxy + HTTPS required!

# OTEA Admin Panel
OTEA_PORT=3000
OTEA_HOST=localhost
# OTEA_HOST=0.0.0.0  # Only if behind firewall/reverse proxy!

# Arma Reforger Server
ARMA_SERVER_ROOT=C:\Arma3DS
# ARMA_SERVER_ROOT=/home/arma/server  # Linux example

# SteamCMD (for auto-updates)
STEAMCMD_PATH=C:\SteamCMD\steamcmd.exe
# STEAMCMD_PATH=/usr/games/steamcmd  # Linux example
# Leave empty if not using SteamCMD:
# STEAMCMD_PATH=

# Authentication
AUTH_PASSWORD=ChangeMe123!
# Use strong password in production (20+ chars)

# Logging
LOG_LEVEL=info
# Levels: error, warn, info, debug
# In production, use: error or warn
