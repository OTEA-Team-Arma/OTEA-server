# OTEA Server - Fichier de configuration (.env.example)
# COPIER CE FICHIER EN ".env.prod" ET REMPLIR LES VALEURS

# === ENVIRONMENT ===
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# === SÉCURITÉ ===
# Changer ABSOLUMENT ces valeurs par défaut
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
API_SECRET_KEY=GENERATE_STRONG_SECRET_WITH_openssl_rand_base64_32
SESSION_SECRET=GENERATE_STRONG_SECRET_WITH_openssl_rand_base64_32

# JWT (si authentification future)
JWT_SECRET=GENERATE_STRONG_SECRET_WITH_openssl_rand_base64_64
JWT_EXPIRY=7d

# === ARMA REFORGER ===
ARMA_SERVER_PATH=/home/arma/server
ARMA_SERVER_BINARY=ArmaReforgerServer
STEAMCMD_PATH=/home/steamcmd/steamcmd

# === CONFIGURATION SERVEUR ===
MAX_INSTANCES=5
DEFAULT_REGION=EU
SERVER_ROOT_PORT_START=2001
SERVER_ROOT_PORT_END=2010

# === DATABASE (futur) ===
DB_HOST=db
DB_PORT=5432
DB_NAME=otea
DB_USER=otea
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# === LOGGING ===
BACKEND_LOG=true
LOG_FILE_PATH=/app/logs/backend.log
LOG_RETENTION_DAYS=30

# === HTTPS/SSL ===
SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem
SSL_AUTO_RENEW=true

# === BACKUP ===
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_PATH=/app/backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=GENERATE_STRONG_SECRET

# === MONITORING ===
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
MONITORING_WEBHOOK_URL=

# === RATE LIMITING ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_API=50
RATE_LIMIT_LOGIN=5

# === CORS ===
CORS_ENABLED=true
CORS_ORIGINS=https://example.com,https://admin.example.com
CORS_CREDENTIALS=true

# === MAIL (alertes - optionnel) ===
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=admin@example.com
MAIL_PASSWORD=MAIL_APP_PASSWORD

# === SLACK NOTIFICATIONS (optionnel) ===
SLACK_WEBHOOK_URL=

# === PROXIES ===
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,db,nginx

# === DEBUG ===
DEBUG=false
VERBOSE_LOGS=false
